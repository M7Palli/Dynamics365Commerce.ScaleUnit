<Project>
  <PropertyGroup>
    <BuildNumber Condition="'$(BuildNumber)' == ''">0.0</BuildNumber>
    <MajorVersion>9.54</MajorVersion>
    <Version>$(MajorVersion).$(BuildNumber)</Version>
  </PropertyGroup>

  <PropertyGroup>
    <Publisher Condition="'$(Publisher)' == ''">CN=Contoso Ltd.</Publisher>
    <PublisherDisplayName Condition="'$(PublisherDisplayName)' == ''">Contoso Ltd.</PublisherDisplayName>
  </PropertyGroup>

  <PropertyGroup>
    <CommerceSdkPackagesVersion>[9.54.*-*,9.55)</CommerceSdkPackagesVersion>
    <CommercePosPackagesVersion>[9.54.*-*,9.55)</CommercePosPackagesVersion>
    <CommerceChannelPackagesVersion>[9.54.*-*,9.55)</CommerceChannelPackagesVersion>
    <CommerceHwsPackagesVersion>[9.54.*-*,9.55)</CommerceHwsPackagesVersion>
    <CommerceToolsPackagesVersion>[10.36.*-*,10.37)</CommerceToolsPackagesVersion>
    <CommercePaymentsPackagesVersion>[10.54.*-*,10.55)</CommercePaymentsPackagesVersion>
  </PropertyGroup>
</Project>
